# Copy this file to .env and fill in your values.
# .env is git-ignored — never commit real credentials.

# ── Spotify ────────────────────────────────────────────────────────────────
# Create an app at https://developer.spotify.com/dashboard
# Set the Redirect URI in the app settings to match SPOTIFY_REDIRECT_URI below.
# NOTE: Spotify requires explicit loopback addresses (127.0.0.1), not localhost
SPOTIFY_CLIENT_ID=your_spotify_client_id_here
SPOTIFY_CLIENT_SECRET=your_spotify_client_secret_here
SPOTIFY_REDIRECT_URI=http://127.0.0.1:8888/callback

# ── Anthropic ──────────────────────────────────────────────────────────────
# Get your key at https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# ── Email (Gmail) ──────────────────────────────────────────────────────────
# Use a Gmail App Password (not your account password):
# Google Account → Security → 2-Step Verification → App passwords
SENDER_EMAIL=you@gmail.com
EMAIL_PASSWORD=your_gmail_app_password
SUBSCRIBER_LIST=you@gmail.com

# ── App config (optional — these are the defaults) ─────────────────────────
DB_PATH=./history.db
SCHEDULE_HOUR=9
SCHEDULE_MINUTE=0
